#!/bin/bash

set -e -o pipefail

{{- if isExecutable "dconf" }} 
{{ range glob (joinPath .chezmoi.workingTree "gnome-shell-extensions/*") }}
{{- $name := base . | trimSuffix (ext .) }}
# {{ $name }} hash: {{ include . | sha256sum }}
dconf load -f "/org/gnome/shell/extensions/{{ $name}}/" < {{ . }}
{{ end }}
{{ else }}
    echo "Skipping Gnome shell extensions setup because 'dconf' executable is not available"
{{ end }}
